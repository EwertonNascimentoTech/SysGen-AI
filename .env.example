# App
APP_NAME=Plataforma Governança IA
SECRET_KEY=altere-em-producao
# JWT (opcional; omissão = HS256 e 24h)
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite dev:
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Produção (docker-compose postgres):
# DATABASE_URL=postgresql+asyncpg://governanca:governanca@127.0.0.1:5432/governanca

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

REDIS_URL=redis://127.0.0.1:6379/0

# --- GitHub OAuth (obrigatório para «OAuth configurado no servidor») ---
# 1) Crie um OAuth App: https://github.com/settings/developers
# 2) Copie este ficheiro para .env na MESMA pasta (raiz plataforma-governanca-ia/) OU em backend/.env
# 3) Authorization callback URL deve coincidir com GITHUB_OAUTH_CALLBACK_URL abaixo
#    (ex. dev: http://127.0.0.1:8000/api/auth/github/callback | Docker UI: http://localhost:8080/api/auth/github/callback)
GITHUB_CLIENT_ID=Ov23liNEs3gHUC7rBVXl
GITHUB_CLIENT_SECRET=c53388a856c5077d3ad0312a74be71f26ff1ec00
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8080/api/auth/github/callback
FRONTEND_OAUTH_REDIRECT_BASE=http://localhost:8080/auth/callback

# Tags, refs e Wiki usam apenas o token OAuth da conta GitHub de cada utilizador (sem PAT partilhado).
#
# Dev local (uvicorn na pasta backend): copie este ficheiro para .env na raiz OU backend/.env.
#
# Docker Compose: o serviço backend só lê compose.env (e variáveis em docker-compose.yml), NÃO o .env da raiz
# dentro do contentor. Copie as chaves Azure (e o que precisar) para compose.env — veja compose.env.example.
# Depois: docker compose up -d --build

# --- MinIO / S3 ---
# S3_ENDPOINT_URL vazio = anexos só em disco local (conforme implementação).
S3_ENDPOINT_URL=http://127.0.0.1:9000
# URL pública para o browser em presigned URLs (opcional)
# S3_PUBLIC_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=governanca
S3_REGION=us-east-1
S3_USE_SSL=false
# S3_PRESIGNED_TTL_SECONDS=3600

# --- Azure AI Agents (chat PRD — prioridade se endpoint + agente definidos) ---
# Projecto / Foundry: https://learn.microsoft.com/azure/ai-services/agents/
# AZURE_AI_PROJECT_ENDPOINT=https://....services.ai.azure.com/api/projects/NOME_DO_PROJECTO
# ou connection string no portal:
# AZURE_AI_PROJECT_CONNECTION_STRING=
# AZURE_AI_AGENT_ID=
# Agente dedicado: gerar prompt de protótipo (aba Protótipo) a partir do último PRD
# AZURE_AI_AGENT_PROTOTIPO_ID=
# Opcional (senão usa DefaultAzureCredential, ex. az login local / managed identity no Azure):
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
#
# --- Azure OpenAI (fallback REST se Agents não estiver completo) ---
# Recurso: https://learn.microsoft.com/azure/ai-services/openai/how-to/create-resource
# AZURE_OPENAI_ENDPOINT=https://SEU_RECURSO.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=nome-do-deployment-gpt
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
#
# Google Stitch API (ecrãs via MCP — ver backend/stitch_runner e STITCH_API_KEY no backend/.env)
# STITCH_API_KEY=
# STITCH_PROJECT_ID=
