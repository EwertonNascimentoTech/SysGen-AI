# App
APP_NAME=Plataforma Governança IA
SECRET_KEY=altere-em-producao
# JWT (opcional; omissão = HS256 e 24h)
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite dev:
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Produção (docker-compose postgres):
# DATABASE_URL=postgresql+asyncpg://governanca:governanca@127.0.0.1:5432/governanca

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

REDIS_URL=redis://127.0.0.1:6379/0

# --- GitHub OAuth (obrigatório para «OAuth configurado no servidor») ---
# 1) Crie um OAuth App: https://github.com/settings/developers
# 2) Copie este ficheiro para .env na MESMA pasta (raiz plataforma-governanca-ia/) OU em backend/.env
# 3) Authorization callback URL deve coincidir com GITHUB_OAUTH_CALLBACK_URL abaixo
#    (ex. dev: http://127.0.0.1:8000/api/auth/github/callback | Docker UI: http://localhost:8080/api/auth/github/callback)
GITHUB_CLIENT_ID=Ov23liNEs3gHUC7rBVXl
GITHUB_CLIENT_SECRET=c53388a856c5077d3ad0312a74be71f26ff1ec00
GITHUB_OAUTH_CALLBACK_URL=http://127.0.0.1:8080/api/auth/github/callback
FRONTEND_OAUTH_REDIRECT_BASE=http://localhost:5173/auth/callback

# Tags, refs e Wiki usam apenas o token OAuth da conta GitHub de cada utilizador (sem PAT partilhado).
#
# Docker: as mesmas variáveis vão em compose.env (na raiz plataforma-governanca-ia/). Se OAuth continuar
# «não configurado», confira se compose.env tem ID e Secret preenchidos e reinicie: docker compose up -d

# --- MinIO / S3 ---
# S3_ENDPOINT_URL vazio = anexos só em disco local (conforme implementação).
S3_ENDPOINT_URL=http://127.0.0.1:9000
# URL pública para o browser em presigned URLs (opcional)
# S3_PUBLIC_ENDPOINT_URL=http://127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=governanca
S3_REGION=us-east-1
S3_USE_SSL=false
# S3_PRESIGNED_TTL_SECONDS=3600
