# Variáveis Azure AI (Agents + OpenAI REST) — ver também o .env.example na raiz do repositório.
#
# Azure AI Agents (prioridade no chat PRD quando endpoint + agent_id estão definidos)
# AZURE_AI_PROJECT_ENDPOINT=https://....services.ai.azure.com/api/projects/NOME
# ou:
# AZURE_AI_PROJECT_CONNECTION_STRING=
# AZURE_AI_AGENT_ID=
# Agente para gerar prompt de protótipo (UX/UI) a partir do último PRD — aba Protótipo
# AZURE_AI_AGENT_PROTOTIPO_ID=
# Agente para planejamento técnico (PRD + export MinIO) — aba Planejamento
# AZURE_AI_AGENT_PLANEJADOR_ID=
# Opcional (senão DefaultAzureCredential): aplicação registada no Entra ID
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_AI_PROJECT_ENDPOINT=https://....services.ai.azure.com/api/projects/NOME_DO_PROJECTO
# AZURE_AI_AGENT_ID=
# AZURE_AI_PROJECT_NAME=
# AZURE_AI_RESOURCE_GROUP=
# AZURE_AI_SUBSCRIPTION_ID=
#
# Azure OpenAI (fallback se Agents não estiver completo)
# AZURE_OPENAI_ENDPOINT=https://RECURSO.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
#
# Google Stitch API (MCP stitch.googleapis.com — pacote @google/stitch-sdk no backend/stitch_runner)
# STITCH_API_KEY=
# STITCH_PROJECT_ID=
#
# Cursor Cloud Agents — quadro «Desenvolver» (URL pública obrigatória para o webhook)
# CURSOR_CLOUD_API_KEY=
# CURSOR_WEBHOOK_SECRET=  # mínimo 32 caracteres
# PUBLIC_API_BASE_URL=https://seu-dominio.com  # sem barra final; expõe POST …/api/webhooks/cursor-agent
