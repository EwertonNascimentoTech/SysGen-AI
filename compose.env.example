# Copie para compose.env na raiz do repositório (compose.env não deve ir para o Git).
# O Docker Compose injeta este ficheiro no backend e no wiki-worker.

SECRET_KEY=altere-em-producao

# GitHub OAuth (igual ao .env.example)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Chat PRD: Azure AI Agents (recomendado; precisa endpoint + agent id) ---
AZURE_AI_PROJECT_ENDPOINT=
# ou: AZURE_AI_PROJECT_CONNECTION_STRING=
AZURE_AI_AGENT_ID=
# Agente para prompt de protótipo (aba Protótipo) a partir do último PRD
# AZURE_AI_AGENT_PROTOTIPO_ID=
# App registration (Entra ID); sem isto no Docker use credencial gerida ou outro método suportado pelo SDK
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Alternativa: Azure OpenAI (REST) — endpoint + key + deployment ---
# AZURE_OPENAI_ENDPOINT=https://SEU_RECURSO.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
